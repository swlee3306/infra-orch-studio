{
  "environment_name": "dev",

  "network": {
    "name": "net1",
    "cidr": "10.0.0.0/24"
  },
  "subnet": {
    "name": "subnet1",
    "cidr": "10.0.0.0/24",
    "enable_dhcp": true
  },
  "instances": [
    {
      "name": "vm1",
      "image": "ubuntu-22.04",
      "flavor": "m1.small",
      "count": 1,
      "ssh_key_name": "mykey",
      "security_groups": ["default"]
    }
  ]
}
